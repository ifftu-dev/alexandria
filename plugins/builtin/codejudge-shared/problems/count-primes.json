{
  "version": "1",
  "id": "count-primes",
  "title": "Count Primes",
  "difficulty": "medium",
  "statement_md": "Read an integer **N**. Print how many prime numbers are strictly less than N.",
  "io": "stdin-stdout",
  "limits": { "time_ms": 2000 },
  "tests": {
    "visible": [
      { "input": "10\n", "output": "4\n", "explain": "2, 3, 5, 7 are the primes below 10" }
    ],
    "hidden": [
      { "input": "0\n", "output": "0\n" },
      { "input": "2\n", "output": "0\n" },
      { "input": "3\n", "output": "1\n" },
      { "input": "20\n", "output": "8\n" },
      { "input": "100\n", "output": "25\n" }
    ]
  }
}
