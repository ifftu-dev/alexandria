{
  "version": "1",
  "id": "reverse-string",
  "title": "Reverse a String",
  "difficulty": "easy",
  "statement_md": "Read a single line of text from stdin and print it reversed (character by character) to stdout.",
  "io": "stdin-stdout",
  "limits": { "time_ms": 2000 },
  "tests": {
    "visible": [
      { "input": "hello\n", "output": "olleh\n" }
    ],
    "hidden": [
      { "input": "abc\n", "output": "cba\n" },
      { "input": "a\n", "output": "a\n" },
      { "input": "racecar\n", "output": "racecar\n" },
      { "input": "Able was I\n", "output": "I saw elbA\n" }
    ]
  }
}
