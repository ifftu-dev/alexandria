# Completion-witness runtime prerequisites.
#
# Source this (after filling in your own Blockfrost creds) before
# running the node or the deploy script:
#   cp scripts/env.completion.example scripts/env.completion
#   edit scripts/env.completion    # add BLOCKFROST_PROJECT_ID
#   source scripts/env.completion
#
# The policy id below is deterministic — it's the blake2b-224 of the
# compiled `completion_minting` validator bytecode in plutus.json.
# Re-run `aiken build` inside cardano/governance/ and recompute the
# hash if you change the validator source.

export ALEXANDRIA_COMPLETION_POLICY_ID="6380450179a6933acdf76213732f8626e1486b9ed5cc7fe7f46c98e0"

# Fill in from your Blockfrost account (https://blockfrost.io).
# Preprod project ids start with "preprod".
export BLOCKFROST_PROJECT_ID=""

# Deployer wallet — only required for deploy_reference_scripts.sh,
# not for running the node itself. Point SIGNING_KEY at a cardano-cli
# .skey file with a few tADA on preprod (faucet: https://docs.cardano.org/cardano-testnet/tools/faucet/).
export DEPLOYER_SIGNING_KEY="$HOME/.cardano/deployer.skey"
export DEPLOYER_ADDRESS=""
