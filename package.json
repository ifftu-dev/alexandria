{
  "name": "alexandria",
  "private": true,
  "version": "0.0.5-alpha",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "seed:up": "cargo run --manifest-path src-tauri/Cargo.toml --features dev-seed --example dev_seed -- up",
    "seed:down": "cargo run --manifest-path src-tauri/Cargo.toml --features dev-seed --example dev_seed -- down",
    "seed:reset": "cargo run --manifest-path src-tauri/Cargo.toml --features dev-seed --example dev_seed -- reset",
    "bump": "bash scripts/bump-version.sh"
  },
  "dependencies": {
    "@choochmeque/tauri-plugin-biometry-api": "^0.2.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-os": "^2.3.2",
    "dompurify": "^3.3.3",
    "force-graph": "^1.51.1",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.1.5"
  }
}
