{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-start-dragging",
    "biometry:default",
    "updater:default",
    "process:allow-restart",
    "deep-link:default",
    "dialog:default",
    "os:allow-locale",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        {
          "path": "$HOME/**"
        }
      ],
      "deny": [
        {
          "path": "$HOME/.ssh/**"
        },
        {
          "path": "$HOME/.gnupg/**"
        },
        {
          "path": "$HOME/.aws/**"
        },
        {
          "path": "$HOME/.config/**"
        },
        {
          "path": "$HOME/Library/**"
        }
      ]
    }
  ]
}
