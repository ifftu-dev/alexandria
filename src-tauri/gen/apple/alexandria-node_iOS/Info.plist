<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<!-- Export compliance: the app uses only standard, published encryption
	     (AES-256/SQLCipher, Ed25519/X25519, Argon2id, TLS/Noise). Because the
	     full source is publicly available (open source), the encryption is
	     exempt under US EAR §742.15(b)/§740.13(e) and the equivalent EU
	     "publicly available" decontrol — which covers France, so no separate
	     ANSSI declaration code is required. Declaring this suppresses the
	     per-upload TestFlight export-compliance prompt. France availability
	     itself is a territory setting in App Store Connect, not a bundle key. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>0.3.3</string>
	<key>CFBundleVersion</key>
	<string>0.3.3</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
		<string>metal</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>Alexandria uses your camera for optional face verification during assessments. All processing happens on-device — no images or video are ever transmitted.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Alexandria may use your microphone for oral assessments. All processing happens on-device — no audio is ever transmitted.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Alexandria uses Face ID or Touch ID to unlock your encrypted vault on this device.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<!-- Deep links: custom scheme alexandria:// . HTTPS app-links on
	     alexandria.ifftu.dev are handled via the associated-domains
	     entitlement + the domain's apple-app-site-association (docs/deeplink/). -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>org.alexandria.node</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>alexandria</string>
			</array>
		</dict>
	</array>
</dict>
</plist>