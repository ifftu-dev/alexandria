<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Foreground service for the libp2p mesh — keeps the process alive
         so Doze / battery optimisation doesn't suspend network traffic
         when the app is backgrounded. See P2pForegroundService.kt. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- POST_NOTIFICATIONS is a runtime permission on Android 13+; the
         service notification is required for foreground-service status. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- AndroidTV support -->
    <uses-feature android:name="android.software.leanback" android:required="false" />

    <application
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.alexandria_node"
        android:usesCleartextTraffic="${usesCleartextTraffic}">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:launchMode="singleTask"
            android:label="@string/main_activity_title"
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <!-- AndroidTV support -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>

            <!-- Deep links: custom scheme alexandria:// (always works, no
                 verification). The plugin only auto-generates the https
                 App-Links filter below (from tauri.conf.json), not the custom
                 scheme, so this one is maintained by hand. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="alexandria" />
            </intent-filter>

            <!-- HTTPS App Links on alexandria.ifftu.dev — auto-generated by
                 tauri-plugin-deep-link. autoVerify requires
                 /.well-known/assetlinks.json served on the domain with this
                 app's release signing SHA-256 (see docs/deeplink/). Until that
                 is hosted + a release keystore exists, https links fall back to
                 the browser; the custom scheme above is unaffected. -->
            <!-- DEEP LINK PLUGIN. AUTO-GENERATED. DO NOT REMOVE. -->
            <intent-filter android:autoVerify="true" >
                <action android:name="android.intent.action.VIEW" />
                <!-- ChromeOS ARC++ uses a different action for deep links -->
                <action android:name="org.chromium.arc.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:scheme="http" />
                <data android:host="alexandria.ifftu.dev" />
                
                
                <data android:pathPrefix="/guardian" />
                <data android:pathPrefix="/course" />
                <data android:pathPrefix="/classroom" />
                <data android:pathPrefix="/open" />
                
            </intent-filter>
            <!-- DEEP LINK PLUGIN. AUTO-GENERATED. DO NOT REMOVE. -->
        </activity>

        <provider
          android:name="androidx.core.content.FileProvider"
          android:authorities="${applicationId}.fileprovider"
          android:exported="false"
          android:grantUriPermissions="true">
          <meta-data
            android:name="android.support.FILE_PROVIDER_PATHS"
            android:resource="@xml/file_paths" />
        </provider>

        <service
            android:name=".P2pForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>
</manifest>
