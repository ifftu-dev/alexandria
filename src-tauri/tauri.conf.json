{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Alexandria",
  "version": "0.0.4-alpha",
  "identifier": "org.alexandria.node",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "features": [
      "tutoring-video"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Alexandria",
        "label": "main",
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 20,
          "y": 24
        },
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'nonce-__TAURI_CSP_NONCE__'; font-src 'self'; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost https://*.blockfrost.io"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "Decentralized learning platform",
    "longDescription": "Alexandria is a free, open-source, decentralized learning platform. Earn blockchain-verified credentials. Study offline. Own your education.",
    "copyright": "Alexandria Contributors",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "./Entitlements.plist"
    },
    "iOS": {
      "developmentTeam": "VLMNL3V44U"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY2MzZCQTE3MDYwMEFEQzUKUldURnJRQUdGN28yOXUwMytkWDJvREM4YTJvcytCZkxUamN5NDM0Rk52RDdaUzluMDNPcFpnRDIK",
      "endpoints": [
        "https://github.com/ifftu-dev/alexandria/releases/latest/download/latest.json"
      ]
    }
  }
}
