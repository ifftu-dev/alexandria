{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Alexandria",
  "version": "0.1.0",
  "identifier": "org.alexandria.node",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Alexandria",
        "label": "main",
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 20,
          "y": 24
        },
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "Decentralized learning platform",
    "longDescription": "Alexandria is a free, open-source, decentralized learning platform. Earn blockchain-verified credentials. Study offline. Own your education.",
    "copyright": "Alexandria Contributors",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "./Entitlements.plist"
    },
    "iOS": {
      "developmentTeam": "VLMNL3V44U"
    }
  }
}
