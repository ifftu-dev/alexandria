{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Alexandria",
  "version": "0.4.3-alpha",
  "identifier": "org.alexandria.node",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build",
    "features": [
      "tutoring-video",
      "dev-seed"
    ]
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Alexandria",
        "label": "main",
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 20,
          "y": 24
        },
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'nonce-__TAURI_CSP_NONCE__'; font-src 'self'; img-src 'self' data: blob:; media-src 'self' blob: asset: http://asset.localhost; frame-src plugin:; connect-src 'self' ipc: http://ipc.localhost https://*.blockfrost.io asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/videocache/**",
          "$APPDATA/profiles/**/videocache/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "Free learning, credentials you own",
    "longDescription": "Alexandria is a free, open-source learning app. Earn verified credentials that are truly yours, study offline, and keep your learning and identity on your own device.",
    "copyright": "Alexandria Contributors",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "./Entitlements.plist",
      "signingIdentity": "Developer ID Application: Pratyush Pundir (VLMNL3V44U)"
    },
    "iOS": {
      "developmentTeam": "VLMNL3V44U",
      "minimumSystemVersion": "16.4"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBQTkzRTUwOEVFQ0E1NzQKUldSMHBleU9VRDZwMmtFTGErYmFsUVN3VXB3em5xR0xsMHllcHRSc1FnREJvNFBKQ21iNEZxSWcK",
      "endpoints": [
        "https://github.com/ifftu-dev/alexandria/releases/latest/download/latest.json"
      ]
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "alexandria"
        ]
      },
      "mobile": [
        {
          "host": "alexandria.ifftu.dev",
          "pathPrefix": [
            "/guardian",
            "/course",
            "/classroom",
            "/open"
          ]
        }
      ]
    }
  }
}
